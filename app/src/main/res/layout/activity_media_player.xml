<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MediaPlayerActivity">
    <LinearLayout android:id="@+id/linearLayout" android:layout_width="match_parent"
        android:orientation="vertical" android:layout_height="match_parent">

        <Button
            android:id="@+id/playButton"
            android:layout_width="107dp"
            android:layout_height="wrap_content"
            android:onClick="onButtonPlayClick"
            android:text="Play" />

        <Button
            android:id="@+id/pauseButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pause"
            android:onClick="onButtonPauseClick"/>
        <Button
            android:id="@+id/nextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Song"
            android:onClick="onButtonNextClick"/>
        <Button
            android:id="@+id/prevButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Previous Song"
            android:onClick="onButtonPrevClick"/>

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="300dp"
            android:layout_height="100dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="10dp"
            android:visibility="visible" />

        <ProgressBar
            android:id="@+id/songProgressBar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:max="1000"
            android:progress="0"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>